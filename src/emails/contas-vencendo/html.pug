doctype html
html(lang="pt-BR")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= subject
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #09090b; color: #f4f4f5; }
      .container { max-width: 600px; margin: 0 auto; padding: 32px 16px; }
      .card { background: #18181b; border: 1px solid #27272a; border-radius: 12px; padding: 32px; }
      .logo { font-size: 22px; font-weight: 700; color: #a78bfa; margin-bottom: 24px; }
      h1 { font-size: 20px; font-weight: 600; color: #f4f4f5; margin-bottom: 8px; }
      .subtitle { font-size: 14px; color: #a1a1aa; margin-bottom: 28px; }
      .bill-list { list-style: none; }
      .bill-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: #09090b; border-radius: 8px; margin-bottom: 8px; border-left: 3px solid #a78bfa; }
      .bill-item.overdue { border-left-color: #f87171; }
      .bill-name { font-size: 14px; font-weight: 500; color: #f4f4f5; }
      .bill-meta { font-size: 12px; color: #71717a; margin-top: 2px; }
      .bill-amount { font-size: 15px; font-weight: 600; color: #a78bfa; white-space: nowrap; margin-left: 16px; }
      .bill-amount.overdue { color: #f87171; }
      .divider { border: none; border-top: 1px solid #27272a; margin: 28px 0; }
      .cta { display: inline-block; background: #7c3aed; color: #fff; text-decoration: none; padding: 12px 24px; border-radius: 8px; font-weight: 600; font-size: 14px; }
      .footer { margin-top: 24px; font-size: 12px; color: #52525b; text-align: center; }
  body
    .container
      .card
        .logo ReConta
        h1 Contas próximas do vencimento
        p.subtitle Olá, #{name}! Aqui está um resumo das suas contas fixas.

        if overdueBills.length > 0
          p(style="font-size: 13px; font-weight: 600; color: #f87171; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.05em;") Vencidas
          ul.bill-list
            each bill in overdueBills
              li.bill-item.overdue
                div
                  p.bill-name= bill.name
                  p.bill-meta Venceu no dia #{bill.dueDay} — #{bill.daysOverdue} dia(s) em atraso
                span.bill-amount.overdue= bill.amountFormatted

        if upcomingBills.length > 0
          if overdueBills.length > 0
            hr.divider
          p(style="font-size: 13px; font-weight: 600; color: #a78bfa; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.05em;") A vencer
          ul.bill-list
            each bill in upcomingBills
              li.bill-item
                div
                  p.bill-name= bill.name
                  p.bill-meta Vence no dia #{bill.dueDay} (em #{bill.daysUntil} dia(s))
                span.bill-amount= bill.amountFormatted

        hr.divider
        a.cta(href=appUrl) Ver no ReConta

      p.footer
        | Você recebeu este e-mail porque as notificações de contas estão ativadas.
        br
        a(href=settingsUrl style="color: #71717a;") Gerenciar notificações
