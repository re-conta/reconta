{
  "name": "reconta",
  "type": "module",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "bun run --cwd web dev",
    "build": "bun run --cwd web build",
    "preview": "bun run --cwd web preview",
    "api:dev": "cd api && go run ./cmd/server",
    "api:build": "cd api && go build -o bin/server ./cmd/server",
    "api:test": "cd api && go test ./..."
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
