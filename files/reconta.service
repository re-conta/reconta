[Unit]
Description=ReConta Next.js Application Service
After=network.target

[Service]
Type=simple
User=nginx
WorkingDirectory=/var/www/reconta
ExecStart=/home/nginx/.local/share/pnpm/pnpm run start
ExecStop=/usr/bin/kill -TERM $MAINPID
Restart=always
RestartSec=10s


[Install]
WantedBy=multi-user.target
